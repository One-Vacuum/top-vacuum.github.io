---
interface Props {
  partNumber: string;
  nameKo: string;
  nameEn: string;
  image: string;
  price: string;
  rawPrice: number;
  category: string;
  descriptionKo?: string;
  descriptionEn?: string;
  bestSeller?: boolean;
}

const { partNumber, nameKo, nameEn, image, price, rawPrice, category, descriptionKo, descriptionEn, bestSeller } = Astro.props;
---

<div
  class:list={[
    'product-card card-flip cursor-pointer h-full',
  ]}
  data-category={category}
  data-price={rawPrice}
  data-best-seller={bestSeller ? '1' : '0'}
  data-part-number={partNumber}
>
  <div class="card-inner">
    <!-- Front -->
    <div class:list={[
      'card-front h-full group/card flex flex-col bg-white dark:bg-gray-800 rounded-xl overflow-hidden shadow-sm transition-shadow duration-300 border border-gray-100 dark:border-gray-700',
      bestSeller && 'ring-2 ring-primary-400/50 dark:ring-primary-500/40',
    ]}>
      {bestSeller ? (
        <div class="bg-primary-500 text-white text-xs font-bold px-3 py-1 text-center" data-i18n="products.bestSeller">BEST</div>
      ) : (
        <div class="text-xs font-bold px-3 py-1">&nbsp;</div>
      )}
      <div class="aspect-square overflow-hidden bg-gray-50 dark:bg-gray-900">
        <img
          src={image}
          alt={nameKo}
          class="w-full h-full object-contain transition-transform duration-300"
          onload="this.loading='eager';if(this.naturalWidth>this.naturalHeight*1.2&&this.naturalWidth<=this.naturalHeight*2){this.classList.remove('object-contain');this.classList.add('object-cover')}"
          onerror="this.src='/images/placeholder-product.svg'"
          loading="lazy"
          decoding="sync"
        />
      </div>
      <div class="p-4 mt-auto">
        <p class="text-xs text-gray-400 dark:text-gray-500 mb-0.5">{partNumber}</p>
        <h3 class="product-name font-semibold text-gray-900 dark:text-gray-100 text-base min-h-[2.5rem] line-clamp-2" data-name-ko={nameKo} data-name-en={nameEn}>{nameKo}</h3>
        {(descriptionKo || descriptionEn) && (
          <p class="product-desc mt-1 text-sm text-gray-500 dark:text-gray-400" data-desc-ko={descriptionKo || ''} data-desc-en={descriptionEn || ''}>{descriptionKo}</p>
        )}
        <p class="mt-2 text-lg font-bold text-primary-600 dark:text-primary-400">{price}</p>
        <p class="mt-2 flex items-center justify-center gap-1 text-[11px] text-gray-300 dark:text-gray-600">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          <span data-i18n="products.tapToFlip">상세정보 보기</span>
        </p>
      </div>
    </div>

    <!-- Back -->
    <div class:list={[
      'card-back flex flex-col items-center justify-center bg-white dark:bg-gray-800 rounded-xl overflow-hidden shadow-sm border border-gray-100 dark:border-gray-700 p-6 text-center',
      bestSeller && 'ring-2 ring-primary-400/50 dark:ring-primary-500/40',
    ]}>
      <p class="text-xs text-gray-400 dark:text-gray-500 mb-2">{partNumber}</p>
      <h3 class="product-name font-semibold text-gray-900 dark:text-gray-100 text-base mb-1" data-name-ko={nameKo} data-name-en={nameEn}>{nameKo}</h3>
      <p class="text-lg font-bold text-primary-600 dark:text-primary-400 mb-6">{price}</p>
      <div class="w-12 h-12 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center mb-3">
        <svg class="w-6 h-6 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
      </div>
      <p class="text-sm text-gray-500 dark:text-gray-400" data-i18n="products.detailComingSoon">상세정보 준비중입니다</p>
    </div>
  </div>
</div>
