---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from './Hero.astro';
import ProductCard from './ProductCard.astro';
import { ui } from '../i18n/ui';
import { loadProducts, formatPrice } from '../lib/products';

const t = ui.ko;
const products = loadProducts();
---

<BaseLayout>
  <Hero />

  <!-- Products Section -->
  <section id="products" class="section bg-white dark:bg-gray-950">
    <div class="container-custom">
      <div class="text-center mb-8">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4" data-i18n="products.title">
          {t['products.title']}
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-400" data-i18n="products.subtitle">
          {t['products.subtitle']}
        </p>
      </div>

      {products.length > 0 ? (
        <>
          <!-- Category Filter + Search + Sort -->
          <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 mb-8">
            <div class="flex flex-wrap justify-center lg:justify-start gap-2" id="category-filters">
              <button data-filter="all" class="filter-btn filter-active" data-i18n="products.filterAll">
                {t['products.filterAll']}
              </button>
              <button data-filter="oil" class="filter-btn" data-i18n="products.filterOil">
                {t['products.filterOil']}
              </button>
              <button data-filter="oil-filter" class="filter-btn" data-i18n="products.filterOilFilter">
                {t['products.filterOilFilter']}
              </button>
              <button data-filter="vacuum-filter" class="filter-btn" data-i18n="products.filterVacuumFilter">
                {t['products.filterVacuumFilter']}
              </button>
            </div>
            <div class="flex flex-col sm:flex-row items-center gap-3">
              <div class="relative w-full sm:w-52">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <input
                  id="search-input"
                  type="text"
                  class="w-full pl-10 pr-10 py-2 text-sm border border-gray-200 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
                  data-i18n-placeholder="products.searchPlaceholder"
                  placeholder={t['products.searchPlaceholder']}
                />
                <button id="search-clear" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 hidden">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>
              <select id="sort-select" class="w-full sm:w-auto px-3 py-2 text-sm border border-gray-200 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary-500">
                <option value="default" data-i18n-option="products.sortDefault">{t['products.sortDefault']}</option>
                <option value="price-asc" data-i18n-option="products.sortPriceAsc">{t['products.sortPriceAsc']}</option>
                <option value="price-desc" data-i18n-option="products.sortPriceDesc">{t['products.sortPriceDesc']}</option>
              </select>
            </div>
          </div>

          <!-- Product Grid -->
          <div id="product-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
            {products.map((product) => (
              <ProductCard
                partNumber={product.partNumber}
                nameKo={product.nameKo}
                nameEn={product.nameEn}
                image={`/products/images/${product.image}`}
                descriptionKo={product.descriptionKo}
                descriptionEn={product.descriptionEn}
                category={product.category}
                price={formatPrice(product.price)}
                rawPrice={product.price}
                bestSeller={product.bestSeller}
              />
            ))}
          </div>

          <!-- Show More Button -->
          <div id="show-more-wrap" class="text-center mt-8">
            <button id="show-more-btn" class="inline-flex items-center gap-2 px-6 py-3 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 font-medium rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
              <span data-i18n="products.showMore">{t['products.showMore']}</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
          </div>

          <!-- Empty filter state -->
          <div id="empty-filter" class="hidden text-center py-16">
            <div class="text-6xl mb-4">📦</div>
            <p class="text-xl text-gray-500 dark:text-gray-400" data-i18n="products.comingSoon">{t['products.comingSoon']}</p>
          </div>
        </>
      ) : (
        <div class="text-center py-16">
          <div class="text-6xl mb-4">📦</div>
          <p class="text-xl text-gray-500 dark:text-gray-400" data-i18n="products.comingSoon">{t['products.comingSoon']}</p>
        </div>
      )}
    </div>
  </section>

  <!-- Where to Buy Section -->
  <section id="buy" class="section bg-gray-50 dark:bg-gray-900">
    <div class="container-custom">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4" data-i18n="buy.title">
          {t['buy.title']}
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-400" data-i18n="buy.subtitle">
          {t['buy.subtitle']}
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-6 justify-center max-w-2xl mx-auto">
        <div
          class="flex-1 flex items-center justify-center gap-3 p-6 bg-gray-100 dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 cursor-not-allowed opacity-60"
        >
          <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
          <span class="font-semibold text-gray-500 dark:text-gray-400" data-i18n="buy.naverStore">{t['buy.naverStore']}</span>
          <span class="text-xs text-gray-400 dark:text-gray-500" data-i18n="buy.comingSoon">{t['buy.comingSoon']}</span>
        </div>

        <div
          class="flex-1 flex items-center justify-center gap-3 p-6 bg-gray-100 dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 cursor-not-allowed opacity-60"
        >
          <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
          <span class="font-semibold text-gray-500 dark:text-gray-400" data-i18n="buy.coupang">{t['buy.coupang']}</span>
          <span class="text-xs text-gray-400 dark:text-gray-500" data-i18n="buy.comingSoon">{t['buy.comingSoon']}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="section bg-white dark:bg-gray-950">
    <div class="container-custom">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4" data-i18n="contact.title">
          {t['contact.title']}
        </h2>
      </div>

      <div class="max-w-3xl mx-auto">
        <div class="grid md:grid-cols-3 gap-8">
          <div class="text-center p-6 rounded-xl bg-gray-50 dark:bg-gray-900">
            <div class="w-12 h-12 bg-primary-100 dark:bg-primary-900/30 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2" data-i18n="contact.phone">{t['contact.phone']}</h3>
            <p class="text-gray-600 dark:text-gray-400" data-i18n="contact.phoneValue">{t['contact.phoneValue']}</p>
          </div>

          <div class="text-center p-6 rounded-xl bg-gray-50 dark:bg-gray-900">
            <div class="w-12 h-12 bg-primary-100 dark:bg-primary-900/30 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2" data-i18n="contact.email">{t['contact.email']}</h3>
            <a href="mailto:sales@gvac.co.kr" class="text-primary-600 dark:text-primary-400 hover:underline" data-i18n="contact.emailValue">{t['contact.emailValue']}</a>
          </div>

          <div class="text-center p-6 rounded-xl bg-gray-50 dark:bg-gray-900">
            <div class="w-12 h-12 bg-primary-100 dark:bg-primary-900/30 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2" data-i18n="contact.address">{t['contact.address']}</h3>
            <p class="text-gray-600 dark:text-gray-400" data-i18n="contact.addressValue">{t['contact.addressValue']}</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { ui } from '../i18n/ui';

  // ===================== Search + Category Filter + Sort + Show More =====================
  const ITEMS_PER_PAGE = 8;
  const filters = document.getElementById('category-filters');
  const productGrid = document.getElementById('product-grid');
  const allCards = Array.from(document.querySelectorAll<HTMLElement>('.product-card'));
  const emptyFilter = document.getElementById('empty-filter');
  const showMoreWrap = document.getElementById('show-more-wrap');
  const showMoreBtn = document.getElementById('show-more-btn');
  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement | null;
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const searchClear = document.getElementById('search-clear');

  let currentFilter = 'all';
  let currentSort = 'default';
  let currentSearch = '';
  let visibleLimit = ITEMS_PER_PAGE;

  function getSortedFilteredCards(): HTMLElement[] {
    let cards = allCards.filter((card) => {
      // Category filter
      if (currentFilter !== 'all' && card.dataset.category !== currentFilter) return false;

      // Search filter
      if (currentSearch) {
        const nameEl = card.querySelector('.product-name') as HTMLElement | null;
        const nameKo = (nameEl?.dataset.nameKo || '').toLowerCase();
        const nameEn = (nameEl?.dataset.nameEn || '').toLowerCase();
        const partNum = (card.dataset.partNumber || '').toLowerCase();
        if (!nameKo.includes(currentSearch) && !nameEn.includes(currentSearch) && !partNum.includes(currentSearch)) return false;
      }

      return true;
    });

    if (currentSort === 'price-asc') {
      cards.sort((a, b) => Number(a.dataset.price) - Number(b.dataset.price));
    } else if (currentSort === 'price-desc') {
      cards.sort((a, b) => Number(b.dataset.price) - Number(a.dataset.price));
    } else {
      // default: best sellers first, then by original order
      cards.sort((a, b) => {
        const aBest = a.dataset.bestSeller === '1' ? 0 : 1;
        const bBest = b.dataset.bestSeller === '1' ? 0 : 1;
        if (aBest !== bBest) return aBest - bBest;
        return allCards.indexOf(a) - allCards.indexOf(b);
      });
    }

    return cards;
  }

  function applyVisibility() {
    const sorted = getSortedFilteredCards();

    // Reorder DOM elements
    if (productGrid) {
      sorted.forEach((card) => productGrid.appendChild(card));
    }

    allCards.forEach((card) => (card.style.display = 'none'));
    sorted.forEach((card, i) => {
      card.style.display = i < visibleLimit ? '' : 'none';
    });

    if (productGrid && emptyFilter) {
      productGrid.style.display = sorted.length > 0 ? '' : 'none';
      emptyFilter.classList.toggle('hidden', sorted.length > 0);
    }

    if (showMoreWrap) {
      showMoreWrap.style.display = sorted.length > visibleLimit ? '' : 'none';
    }
  }

  applyVisibility();

  filters?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.filter-btn') as HTMLButtonElement | null;
    if (!btn) return;

    currentFilter = btn.dataset.filter || 'all';
    visibleLimit = ITEMS_PER_PAGE;

    filters.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('filter-active'));
    btn.classList.add('filter-active');

    applyVisibility();
  });

  sortSelect?.addEventListener('change', () => {
    currentSort = sortSelect.value;
    visibleLimit = ITEMS_PER_PAGE;
    applyVisibility();
  });

  showMoreBtn?.addEventListener('click', () => {
    visibleLimit += ITEMS_PER_PAGE;
    applyVisibility();
  });

  searchInput?.addEventListener('input', () => {
    currentSearch = (searchInput.value || '').trim().toLowerCase();
    visibleLimit = ITEMS_PER_PAGE;
    if (searchClear) {
      searchClear.classList.toggle('hidden', !currentSearch);
    }
    applyVisibility();
  });

  searchClear?.addEventListener('click', () => {
    if (searchInput) searchInput.value = '';
    currentSearch = '';
    searchClear.classList.add('hidden');
    visibleLimit = ITEMS_PER_PAGE;
    applyVisibility();
  });

  // ===================== Card Flip =====================
  productGrid?.addEventListener('click', (e) => {
    const card = (e.target as HTMLElement).closest('.card-flip') as HTMLElement | null;
    if (!card) return;
    card.classList.toggle('flipped');
  });

  // ===================== Language Toggle =====================
  let currentLang: 'ko' | 'en' = 'ko';

  const btnKO = document.getElementById('btnKO')!;
  const btnEN = document.getElementById('btnEN')!;
  const toggleActive = 'px-2.5 py-1 text-xs font-medium rounded-md bg-primary-500/15 text-primary-700 dark:bg-primary-500/20 dark:text-primary-400 transition-colors';
  const toggleInactive = 'px-2.5 py-1 text-xs font-medium rounded-md text-slate-500 dark:text-gray-500 hover:text-slate-600 dark:hover:text-gray-300 transition-colors';

  function setLang(lang: 'ko' | 'en') {
    currentLang = lang;

    // Update toggle buttons
    btnKO.className = lang === 'ko' ? toggleActive : toggleInactive;
    btnEN.className = lang === 'en' ? toggleActive : toggleInactive;

    // Update html lang attribute
    document.documentElement.lang = lang;

    // Update all data-i18n elements
    const translations = ui[lang];
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
      const key = el.dataset.i18n as keyof typeof translations;
      const value = translations[key] || ui.ko[key];
      if (!value) return;

      if (el.tagName === 'TITLE') {
        document.title = value;
      } else if (el.tagName === 'META') {
        el.setAttribute('content', value);
      } else {
        el.textContent = value;
      }
    });

    // Update select option elements
    document.querySelectorAll<HTMLOptionElement>('[data-i18n-option]').forEach((el) => {
      const key = el.dataset.i18nOption as keyof typeof translations;
      const value = translations[key] || ui.ko[key];
      if (value) el.textContent = value;
    });

    // Update placeholder attributes
    document.querySelectorAll<HTMLElement>('[data-i18n-placeholder]').forEach((el) => {
      const key = (el as HTMLElement).dataset.i18nPlaceholder as keyof typeof translations;
      const value = translations[key] || ui.ko[key];
      if (value) (el as HTMLInputElement).placeholder = value;
    });

    // Update product names and descriptions
    document.querySelectorAll<HTMLElement>('.product-name').forEach((el) => {
      el.textContent = (lang === 'ko' ? el.dataset.nameKo : el.dataset.nameEn) || '';
    });
    document.querySelectorAll<HTMLElement>('.product-desc').forEach((el) => {
      el.textContent = (lang === 'ko' ? el.dataset.descKo : el.dataset.descEn) || '';
    });

    // Hide/show hero subtitle (empty in English)
    const heroSubtitle = document.getElementById('hero-subtitle');
    if (heroSubtitle) {
      heroSubtitle.style.display = heroSubtitle.textContent ? '' : 'none';
    }
  }

  function toggleLang() {
    setLang(currentLang === 'ko' ? 'en' : 'ko');
  }
  btnKO.addEventListener('click', toggleLang);
  btnEN.addEventListener('click', toggleLang);
</script>
