---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { ui } from '../i18n/ui';

const t = ui.ko;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={t['site.description']} data-i18n="site.description" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@700;800;900&display=swap" rel="stylesheet" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
      rel="stylesheet"
    />
    <title data-i18n="site.title">{t['site.title']}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- KakaoTalk Floating Button -->
    <button
      id="kakao-btn"
      class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#FEE500] hover:bg-[#FDD835] rounded-full shadow-lg hover:shadow-xl transition-all duration-200 flex items-center justify-center group"
      aria-label="KakaoTalk"
    >
      <svg class="w-8 h-8" viewBox="0 0 256 256" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M128 36C70.6 36 24 72.2 24 116.8c0 29 19.5 54.4 48.8 68.8-2.1 7.9-7.7 28.5-8.8 33-.1.5-.2 1-.2 1.5 0 1.8 1.5 3.2 3.3 3.2.9 0 1.7-.3 2.4-.9 8.3-5.8 30.4-21 43-29.8 5.1.7 10.3 1 15.5 1 57.4 0 104-36.2 104-80.8S185.4 36 128 36z" fill="#3C1E1E"/>
      </svg>
      <span class="hidden md:block absolute bottom-full right-0 mb-2 px-3 py-1.5 bg-gray-900 text-white text-xs rounded-lg whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none" data-i18n="kakao.tooltip">
        카카오톡 문의
      </span>
    </button>

    <!-- KakaoTalk Toast -->
    <div id="kakao-toast" class="fixed bottom-24 right-6 z-50 px-4 py-3 bg-gray-900 text-white text-sm rounded-lg shadow-lg transition-all duration-300 opacity-0 translate-y-2 pointer-events-none">
      <span data-i18n="kakao.comingSoon">카카오톡 채널 준비중입니다.</span>
    </div>

    <script>
      const kakaoBtn = document.getElementById('kakao-btn');
      const kakaoToast = document.getElementById('kakao-toast');
      let toastTimer: ReturnType<typeof setTimeout>;

      kakaoBtn?.addEventListener('click', () => {
        if (!kakaoToast) return;
        clearTimeout(toastTimer);
        kakaoToast.classList.remove('opacity-0', 'translate-y-2');
        kakaoToast.classList.add('opacity-100', 'translate-y-0');
        toastTimer = setTimeout(() => {
          kakaoToast.classList.remove('opacity-100', 'translate-y-0');
          kakaoToast.classList.add('opacity-0', 'translate-y-2');
        }, 1500);
      });
    </script>
  </body>
</html>
